# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://gokon:gokon_pass@localhost:5432/gokon_db"

# JWT
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Storage (for photos)
STORAGE_PATH=./uploads

# CORS
CORS_ORIGINS=http://localhost:8081,exp://localhost:8081

# Backend root redirect
APP_ROOT_REDIRECT_URL=http://localhost:8081

# Mobile – LAN IP of this machine so phone/Expo Go can reach the backend & Metro bundler.
# Run `ipconfig` (Windows) or `ifconfig` (Mac/Linux) to find your LAN IP.
# Leave blank to use host.docker.internal (Docker Desktop on Windows/Mac only).
HOST_IP=
